{
  "name": "vizorix-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspace=@vizorix/shared && npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
