# Git Attributes configuration for Vizorix monorepo
# Enforces consistent line endings across Windows, macOS, and Linux

# Set default behavior to normalize line endings
* text=auto

# Enforce LF line endings for text/source files
*.java text eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf
.eslintrc* text eol=lf

# Declare binary files that must not be modified by line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.war binary
*.zip binary
*.tar.gz binary
