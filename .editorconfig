# EditorConfig configuration for Vizorix monorepo
# See http://editorconfig.org for details

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.java]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
insert_final_newline = true

[*.{sh,bash}]
end_of_line = lf
indent_style = space
indent_size = 2
